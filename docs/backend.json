
{
  "entities": {
    "Admin": {
      "title": "Admin",
      "type": "object",
      "description": "Represents an administrative user.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      }
    },
    "ExternalSaver": {
      "title": "ExternalSaver",
      "type": "object",
      "description": "Represents a non-student/non-teacher saver.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "SavingsTransaction": {
      "title": "SavingsTransaction",
      "type": "object",
      "description": "Represents a deposit or withdrawal in the savings system.",
      "properties": {
        "id": { "type": "string" },
        "saverId": { "type": "string" },
        "saverName": { "type": "string" },
        "saverType": { "type": "string", "enum": ["student", "teacher", "external"] },
        "type": { "type": "string", "enum": ["deposit", "withdraw"] },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      }
    },
    "Teacher": {
      "title": "Teacher",
      "type": "object",
      "description": "Represents a teacher.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "jabatan": { "type": "string" },
        "noWa": { "type": "string" },
        "nik": { "type": "string" },
        "pendidikan": { "type": "string" },
        "ponpes": { "type": "string" },
        "alamat": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "dokumenUrl": { "type": "string" }
      }
    },
    "Student": {
      "title": "Student",
      "type": "object",
      "description": "Represents a student.",
      "properties": {
        "id": { "type": "string" },
        "nis": { "type": "string" },
        "name": { "type": "string" },
        "kelas": { "type": "number" },
        "password": { "type": "string" },
        "address": { "type": "string" },
        "noWa": { "type": "string" },
        "reportUrl": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "nik": { "type": "string" },
        "gender": { "type": "string" },
        "dateOfBirth": { "type": "string" }
      }
    },
    "SchoolProfile": {
      "title": "SchoolProfile",
      "type": "object",
      "description": "Main school configuration.",
      "properties": {
        "namaMadrasah": { "type": "string" },
        "namaYayasan": { "type": "string" },
        "nsdt": { "type": "string" },
        "alamat": { "type": "string" },
        "logoMadrasahUrl": { "type": "string" },
        "logoYayasanUrl": { "type": "string" },
        "kopSuratUrl": { "type": "string" },
        "activeAcademicYear": { "type": "string" },
        "defaultSppAmount": { "type": "number" },
        "visi": { "type": "string" },
        "misi": { "type": "string" },
        "sejarahSingkat": { "type": "string" }
      }
    },
    "StudentAttendance": {
      "title": "StudentAttendance",
      "type": "object",
      "description": "Daily attendance for students.",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "nis": { "type": "string" },
        "kelas": { "type": "number" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["Hadir", "Sakit", "Izin", "Alpa"] }
      }
    },
    "TeacherAttendance": {
      "title": "TeacherAttendance",
      "type": "object",
      "description": "Daily attendance for teachers.",
      "properties": {
        "id": { "type": "string" },
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["Hadir", "Sakit", "Izin", "Alpa"] }
      }
    },
    "SPPPayment": {
      "title": "SPPPayment",
      "type": "object",
      "description": "Monthly SPP payment records.",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "classId": { "type": "string" },
        "month": { "type": "number" },
        "year": { "type": "number" },
        "amountPaid": { "type": "number" },
        "status": { "type": "string" },
        "paymentDate": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "Announcement": {
      "title": "Announcement",
      "type": "object",
      "description": "News and announcements.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "linkUrl": { "type": "string" },
        "target": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "Grade": {
      "title": "Grade",
      "type": "object",
      "description": "Student subject grades.",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "subjectId": { "type": "string" },
        "score": { "type": "number" },
        "type": { "type": "string" },
        "academicYear": { "type": "string" }
      }
    },
    "ReportSummary": {
      "title": "ReportSummary",
      "type": "object",
      "description": "End of semester summaries.",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "academicYear": { "type": "string" },
        "semester": { "type": "string" },
        "status": { "type": "string" },
        "sakit": { "type": "number" },
        "izin": { "type": "number" },
        "alpa": { "type": "number" }
      }
    },
    "Curriculum": {
      "title": "Curriculum",
      "type": "object",
      "description": "School subjects.",
      "properties": {
        "id": { "type": "string" },
        "subjectCode": { "type": "string" },
        "subjectName": { "type": "string" },
        "classLevel": { "type": "number" },
        "bookName": { "type": "string" }
      }
    },
    "Schedule": {
      "title": "Schedule",
      "type": "object",
      "description": "Class schedules.",
      "properties": {
        "id": { "type": "string" },
        "classLevel": { "type": "number" },
        "academicYear": { "type": "string" },
        "type": { "type": "string" }
      }
    },
    "Certificate": {
      "title": "Certificate",
      "type": "object",
      "description": "Student achievement awards.",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "rank": { "type": "string" },
        "category": { "type": "string" },
        "competitionName": { "type": "string" },
        "date": { "type": "string" },
        "academicYear": { "type": "string" }
      }
    },
    "CertificateTemplate": {
      "title": "CertificateTemplate",
      "type": "object",
      "description": "Background images for certificates.",
      "properties": {
        "id": { "type": "string" },
        "imageUrl": { "type": "string" }
      }
    },
    "Alumni": {
      "title": "Alumni",
      "type": "object",
      "description": "Graduated students.",
      "properties": {
        "id": { "type": "string" },
        "nis": { "type": "string" },
        "name": { "type": "string" },
        "tahunLulus": { "type": "string" },
        "address": { "type": "string" },
        "noWa": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/admins/{adminId}": {
      "schema": { "$ref": "#/backend/entities/Admin" },
      "description": "Admin users collection."
    },
    "/externalSavers/{saverId}": {
      "schema": { "$ref": "#/backend/entities/ExternalSaver" },
      "description": "Non-internal savers."
    },
    "/savingsTransactions/{transactionId}": {
      "schema": { "$ref": "#/backend/entities/SavingsTransaction" },
      "description": "History of all savings movements."
    },
    "/schoolProfile/{id}": {
      "schema": { "$ref": "#/backend/entities/SchoolProfile" },
      "description": "School settings."
    },
    "/teachers/{id}": {
      "schema": { "$ref": "#/backend/entities/Teacher" },
      "description": "Teacher data."
    },
    "/students/{id}": {
      "schema": { "$ref": "#/backend/entities/Student" },
      "description": "Student data."
    },
    "/student_attendances/{id}": {
      "schema": { "$ref": "#/backend/entities/StudentAttendance" },
      "description": "Student attendance history."
    },
    "/teacher_attendances/{id}": {
      "schema": { "$ref": "#/backend/entities/TeacherAttendance" },
      "description": "Teacher attendance history."
    },
    "/sppPayments/{id}": {
      "schema": { "$ref": "#/backend/entities/SPPPayment" },
      "description": "SPP payments history."
    },
    "/announcements/{id}": {
      "schema": { "$ref": "#/backend/entities/Announcement" },
      "description": "Announcements collection."
    },
    "/grades/{id}": {
      "schema": { "$ref": "#/backend/entities/Grade" },
      "description": "Student grades."
    },
    "/report_summaries/{id}": {
      "schema": { "$ref": "#/backend/entities/ReportSummary" },
      "description": "Report summaries."
    },
    "/curriculum/{id}": {
      "schema": { "$ref": "#/backend/entities/Curriculum" },
      "description": "Subjects collection."
    },
    "/schedules/{id}": {
      "schema": { "$ref": "#/backend/entities/Schedule" },
      "description": "Class schedules."
    },
    "/certificates/{id}": {
      "schema": { "$ref": "#/backend/entities/Certificate" },
      "description": "Awards records."
    },
    "/certificate_templates/{id}": {
      "schema": { "$ref": "#/backend/entities/CertificateTemplate" },
      "description": "Backgrounds for certificates."
    },
    "/alumni/{id}": {
      "schema": { "$ref": "#/backend/entities/Alumni" },
      "description": "Alumni collection."
    }
  }
}
