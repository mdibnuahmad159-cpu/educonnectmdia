
{
  "entities": {
    "Admin": {
      "title": "Admin",
      "type": "object",
      "description": "Represents an administrative user.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      }
    },
    "ExternalSaver": {
      "title": "ExternalSaver",
      "type": "object",
      "description": "Represents a non-student/non-teacher saver.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "SavingsTransaction": {
      "title": "SavingsTransaction",
      "type": "object",
      "description": "Represents a deposit or withdrawal in the savings system.",
      "properties": {
        "id": { "type": "string" },
        "saverId": { "type": "string" },
        "saverType": { "type": "string", "enum": ["student", "teacher", "external"] },
        "type": { "type": "string", "enum": ["deposit", "withdraw"] },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      }
    },
    "Teacher": {
      "title": "Teacher",
      "type": "object",
      "description": "Represents a teacher.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "jabatan": { "type": "string" },
        "noWa": { "type": "string" },
        "nik": { "type": "string" },
        "pendidikan": { "type": "string" },
        "ponpes": { "type": "string" },
        "alamat": { "type": "string" }
      }
    },
    "Student": {
      "title": "Student",
      "type": "object",
      "description": "Represents a student.",
      "properties": {
        "id": { "type": "string" },
        "nis": { "type": "string" },
        "name": { "type": "string" },
        "kelas": { "type": "number" },
        "password": { "type": "string" },
        "address": { "type": "string" },
        "noWa": { "type": "string" },
        "reportUrl": { "type": "string" }
      }
    },
    "SchoolProfile": {
      "title": "SchoolProfile",
      "type": "object",
      "description": "Main school configuration.",
      "properties": {
        "namaMadrasah": { "type": "string" },
        "alamat": { "type": "string" },
        "logoMadrasahUrl": { "type": "string" },
        "activeAcademicYear": { "type": "string" },
        "defaultSppAmount": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/admins/{adminId}": {
      "schema": { "$ref": "#/entities/Admin" },
      "description": "Admin users collection."
    },
    "/externalSavers/{saverId}": {
      "schema": { "$ref": "#/entities/ExternalSaver" },
      "description": "Non-internal savers."
    },
    "/savingsTransactions/{transactionId}": {
      "schema": { "$ref": "#/entities/SavingsTransaction" },
      "description": "History of all savings movements."
    },
    "/schoolProfile/{id}": {
      "schema": { "$ref": "#/entities/SchoolProfile" },
      "description": "School settings."
    },
    "/teachers/{id}": {
      "schema": { "$ref": "#/entities/Teacher" },
      "description": "Teacher data."
    },
    "/students/{id}": {
      "schema": { "$ref": "#/entities/Student" },
      "description": "Student data."
    }
  }
}
