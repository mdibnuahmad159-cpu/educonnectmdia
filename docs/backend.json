
{
  "entities": {
    "Admin": {
      "title": "Admin",
      "type": "object",
      "description": "Represents an administrative user.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      }
    },
    "ExternalSaver": {
      "title": "ExternalSaver",
      "type": "object",
      "description": "Represents a non-student/non-teacher saver.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "SavingsTransaction": {
      "title": "SavingsTransaction",
      "type": "object",
      "description": "Represents a deposit or withdrawal in the savings system.",
      "properties": {
        "id": { "type": "string" },
        "saverId": { "type": "string" },
        "saverType": { "type": "string", "enum": ["student", "teacher", "external"] },
        "type": { "type": "string", "enum": ["deposit", "withdraw"] },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      }
    },
    "Teacher": {
      "title": "Teacher",
      "type": "object",
      "description": "Represents a teacher.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "Student": {
      "title": "Student",
      "type": "object",
      "description": "Represents a student.",
      "properties": {
        "id": { "type": "string" },
        "nis": { "type": "string" },
        "name": { "type": "string" },
        "kelas": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": {
      "/admins/{adminId}": {
        "schema": "#/entities/Admin",
        "description": "Admin users collection."
      },
      "/externalSavers/{saverId}": {
        "schema": "#/entities/ExternalSaver",
        "description": "Non-internal savers."
      },
      "/savingsTransactions/{transactionId}": {
        "schema": "#/entities/SavingsTransaction",
        "description": "History of all savings movements."
      }
    }
  }
}
