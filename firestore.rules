
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'mdibnuahmad159@gmail.com' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    // Super-Admin Override: Akses penuh untuk administrator
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // Akses profil sekolah publik
    match /schoolProfile/{profileId} {
      allow read: if true;
    }

    // Aturan akses umum untuk pengguna terautentikasi
    match /announcements/{announcementId} { allow read: if isSignedIn(); }
    match /teachers/{teacherId} { 
      allow get, update: if isSignedIn() && request.auth.uid == teacherId;
      allow list: if isSignedIn();
    }
    match /students/{studentId} { allow read: if isSignedIn(); }
    match /classes/{id} { allow read: if isSignedIn(); }
    match /curriculum/{id} { allow read: if isSignedIn(); }
    match /alumni/{id} { allow read: if isSignedIn(); }
    match /schedules/{id} { allow read: if isSignedIn(); }
    match /grades/{id} { allow read: if isSignedIn(); }
    match /report_summaries/{id} { allow read: if isSignedIn(); }
    match /certificates/{id} { allow read: if isSignedIn(); }
    match /certificate_templates/{id} { allow read: if isSignedIn(); }
    
    // Pembayaran SPP
    match /sppPayments/{paymentId} {
      allow read: if isSignedIn();
      allow write, delete: if isAdmin();
    }

    // Penabung Luar
    match /externalSavers/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // Transaksi Tabungan - Izinkan list untuk kueri riwayat
    match /savingsTransactions/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // Izin eksplisit untuk listing koleksi (dibutuhkan oleh beberapa kueri)
    match /savingsTransactions {
      allow list: if isSignedIn();
    }
    match /externalSavers {
      allow list: if isSignedIn();
    }

    match /teacher_attendances/{id} { allow read: if isSignedIn(); }
    match /student_attendances/{id} { allow read: if isSignedIn(); }
  }
}
