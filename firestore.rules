rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SCHOOL MANAGEMENT & SPP PAYMENT SYSTEM - SECURITY RULES
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the user is an admin by role document OR by primary admin email. */
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.email == 'mdibnuahmad159@gmail.com'
      );
    }

    /** Retrieves the teacherId associated with the current user's UID. */
    function getTeacherId() {
      return get(/databases/$(database)/documents/roles_teacher/$(request.auth.uid)).data.teacherId;
    }

    /** Retrieves the studentId associated with the current user's UID (Parent role). */
    function getStudentId() {
      return get(/databases/$(database)/documents/roles_parent/$(request.auth.uid)).data.studentId;
    }

    // --- Role Collections ---

    match /roles_admin/{adminUid} {
      allow get: if isAdmin() || (isSignedIn() && request.auth.uid == adminUid);
      allow list, write: if isAdmin();
    }

    match /roles_teacher/{teacherUid} {
      allow get: if isAdmin() || (isSignedIn() && request.auth.uid == teacherUid);
      allow list, write: if isAdmin();
    }

    match /roles_parent/{parentUid} {
      allow get: if isAdmin() || (isSignedIn() && request.auth.uid == parentUid);
      allow list, write: if isAdmin();
    }

    // --- Business Entities ---

    /** Publicly readable for login branding. */
    match /schoolProfile/{profileId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /classes/{classId} {
      allow get, list: if isAdmin() || (isSignedIn() && resource.data.homeroomTeacherId == getTeacherId());
      allow create, update, delete: if isAdmin();
    }

    match /teachers/{teacherId} {
      allow get: if isAdmin() || (isSignedIn() && getTeacherId() == teacherId);
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /students/{studentId} {
      allow get: if isAdmin() || (isSignedIn() && (getStudentId() == studentId || getTeacherId() != null));
      allow list: if isAdmin() || (isSignedIn() && (getStudentId() == studentId || getTeacherId() != null));
      allow create, update, delete: if isAdmin();
    }

    match /sppPayments/{sppPaymentId} {
      allow get, list: if isAdmin() || (isSignedIn() && (resource.data.studentId == getStudentId() || resource.data.homeroomTeacherId == getTeacherId()));
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.homeroomTeacherId == getTeacherId());
      allow update: if (isAdmin() || (isSignedIn() && resource.data.homeroomTeacherId == getTeacherId()))
                    && request.resource.data.studentId == resource.data.studentId
                    && request.resource.data.homeroomTeacherId == resource.data.homeroomTeacherId;
      allow delete: if isAdmin();
    }

    // --- Additional Collections ---

    match /announcements/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /curriculum/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /alumni/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /schedules/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /teacher_attendances/{id} { allow read: if isAdmin() || isSignedIn(); allow write: if isAdmin(); }
    match /student_attendances/{id} { allow read: if isAdmin() || isSignedIn(); allow write: if isAdmin(); }
    match /grades/{id} { allow read: if isAdmin() || isSignedIn(); allow write: if isAdmin(); }
    match /report_summaries/{id} { allow read: if isAdmin() || isSignedIn(); allow write: if isAdmin(); }
    match /certificates/{id} { allow read: if isAdmin() || isSignedIn(); allow write: if isAdmin(); }
    match /certificate_templates/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
  }
}