
/**
 * # Firestore Security Rules: EduConnect
 *
 * ## Core Philosophy
 * Aturan ini menggunakan model Role-Based Access Control (RBAC).
 * 1. Super-Admin: Email khusus 'mdibnuahmad159@gmail.com' memiliki akses penuh ke semua data.
 * 2. Regular Users: Guru dan Wali Murid memiliki akses terbatas berdasarkan peran mereka.
 * 3. Default: Tolak semua akses yang tidak didefinisikan secara eksplisit.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================

    /** Cek apakah pengguna sudah login */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Cek apakah pengguna adalah Super-Admin */
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'mdibnuahmad159@gmail.com';
    }
    
    /** Cek apakah pengguna adalah Guru terdaftar */
    function isTeacher() {
      return exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }

    /** Cek apakah pengguna adalah Wali Murid (termasuk anonim untuk login) */
    function isParent() {
      return (isSignedIn() && request.auth.token.firebase.sign_in_provider == 'anonymous')
          || exists(/databases/$(database)/documents/parents/$(request.auth.uid));
    }

    // =====================================================================
    // Super-Admin Override
    // =====================================================================
    // Memberikan akses penuh ke semua jalur untuk administrator
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // =====================================================================
    // Specific Collection Rules (Untuk Non-Admin)
    // =====================================================================

    /** Pengumuman: Semua yang login bisa baca, hanya admin yang bisa tulis (sudah dihandle super-admin) */
    match /announcements/{announcementId} {
      allow read: if isSignedIn();
    }

    /** Profil Guru: Guru bisa baca/ubah profil sendiri */
    match /teachers/{teacherId} {
      allow get, update: if isSignedIn() && request.auth.uid == teacherId;
    }

    /** Profil Wali Murid: Wali bisa baca/ubah profil sendiri */
    match /parents/{parentId} {
      allow get, update: if isSignedIn() && request.auth.uid == parentId;
    }

    /** Data Siswa: Guru dan Wali Murid bisa baca data siswa tertentu */
    match /students/{studentId} {
      // Izinkan akses 'get' tanpa login untuk proses pengecekan NIS saat login parent
      allow get: if request.auth == null || isTeacher() || isParent();
      allow list: if isTeacher();
    }

    /** Data Akademik & Sekolah: Bisa dibaca oleh semua yang login */
    match /classes/{classId} { allow read: if isSignedIn(); }
    match /subjects/{subjectId} { allow read: if isSignedIn(); }
    match /curriculum/{curriculumId} { allow read: if isSignedIn(); }
    match /alumni/{alumniId} { allow read: if isSignedIn(); }
    match /schedules/{scheduleId} { allow read: if isSignedIn(); }
    match /schoolProfile/{profileId} { allow read: if isSignedIn(); }

    /** Absensi: Hanya Admin yang bisa baca/tulis (sudah dihandle oleh Super-Admin rule) */
    match /teacher_attendances/{attendanceId} {
      allow read, write: if false; // Hanya admin lewat super-admin rule
    }
    match /student_attendances/{attendanceId} {
      allow read, write: if false; // Hanya admin lewat super-admin rule
    }
  }
}
