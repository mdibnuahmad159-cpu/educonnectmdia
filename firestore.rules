
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Fungsi pembantu untuk mengecek status login
    function isSignedIn() {
      return request.auth != null;
    }

    // Fungsi pembantu untuk mengecek apakah user adalah admin utama
    function isAdmin() {
      return isSignedIn() && (request.auth.token.email == 'mdibnuahmad159@gmail.com' || request.auth.uid == 'ILjpJZ1CcEhC6qlN9JpHwj0Bj773');
    }
    
    // Fungsi pembantu untuk mengecek apakah user adalah guru terdaftar
    // Catatan: isTeacher() lama tidak berfungsi untuk portal anonim karena mengecek UID Auth.
    // Untuk portal guru/wali, kita mengandalkan isSignedIn() pada koleksi spesifik.
    function isTeacher() {
      return isSignedIn() && exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }

    // Aturan Global: 
    // 1. Semua pengguna yang login bisa membaca data
    // 2. Hanya admin utama yang bisa melakukan penulisan secara umum
    match /{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Izin spesifik untuk Guru dan Portal (Input Nilai, Absensi, dan Tabungan)
    // Karena sistem menggunakan portal anonim untuk Guru dan Wali Murid, 
    // izin penulisan diberikan kepada semua pengguna yang telah login.
    // Validasi logika keamanan tingkat lanjut ditangani di tingkat aplikasi.
    match /grades/{id} {
      allow write: if isSignedIn();
    }
    
    match /student_attendances/{id} {
      allow write: if isSignedIn();
    }
    
    match /report_summaries/{id} {
      allow write: if isSignedIn();
    }
    
    match /savingsTransactions/{id} {
      allow write: if isSignedIn();
    }

    // Pengecualian khusus: Profil sekolah bisa dibaca publik (untuk halaman login)
    match /schoolProfile/{id} {
      allow read: if true;
    }
    
    // Izin spesifik untuk template sertifikat
    match /certificate_templates/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
