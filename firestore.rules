
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'mdibnuahmad159@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    // Default rules for authenticated users
    // Allow read for anyone signed in to ensure listing/queries work across all collections
    match /{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // School profile is read-only for public, write for admin
    match /schoolProfile/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Explicit rules for attendance to ensure queries (list) are permitted
    match /student_attendances/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /teacher_attendances/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /savingsTransactions/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /sppPayments/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
