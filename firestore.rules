rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Fungsi pembantu untuk mengecek status login
    function isSignedIn() {
      return request.auth != null;
    }

    // Fungsi pembantu untuk mengecek apakah user adalah admin utama
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'mdibnuahmad159@gmail.com';
    }

    // Aturan Global: 
    // 1. Semua pengguna yang login bisa membaca data (untuk guru dan wali murid)
    // 2. Hanya admin utama yang bisa menambah/mengubah/menghapus data
    match /{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Pengecualian khusus: Profil sekolah bisa dibaca publik (untuk halaman login)
    match /schoolProfile/{id} {
      allow read: if true;
    }
  }
}