rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * EDUCONNECT SECURITY RULES
     * 
     * Core Philosophy:
     * This ruleset implements a Database-Based Access Control (DBAC) model where user roles
     * (Admin, Teacher, Parent) are determined by the existence of a document in their
     * respective role collections, with the document ID matching the Firebase Auth UID.
     * 
     * Data Structure:
     * - Top-level collections: /admins, /teachers, /parents, /classes, /students.
     * - Flat hierarchy optimized for direct access and secure querying.
     * 
     * Key Security Decisions:
     * - Authorization Independence: Critical fields (homeroomTeacherId, parentIds) are 
     *   denormalized onto Student and Class documents to allow for high-performance 
     *   authorization checks without cross-document get() calls.
     * - Admin Dominance: Users in the /admins collection have full CRUD access across 
     *   the entire database.
     * - Path-to-Data Integrity: For user profiles, the UID in the path must match the 
     *   internal 'id' field.
     * 
     * Prototyping Mode:
     * These rules enforce strict authorization (who can access) but allow for 
     * flexible data shapes (what they can write) to facilitate rapid development.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAssignedTeacher(homeroomTeacherId) {
      return isSignedIn() && request.auth.uid == homeroomTeacherId;
    }

    function isAssociatedParent(parentIds) {
      return isSignedIn() && request.auth.uid in parentIds;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for Admin profiles. Grants administrative powers to the user.
     * @path /admins/{adminId}
     * @allow (get, list) if the user is the owner or an existing admin.
     * @allow (create) if the user is creating their own admin record.
     * @allow (update, delete) if the user is an existing admin.
     * @principle Role-based access control via document existence and ownership.
     */
    match /admins/{adminId} {
      allow get, list: if isOwner(adminId) || isAdmin();
      allow create: if isOwner(adminId) && request.resource.data.id == adminId;
      allow update: if (isOwner(adminId) || isAdmin()) && resource != null && request.resource.data.id == adminId;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Rules for Teacher profiles.
     * @path /teachers/{teacherId}
     * @allow (get, list) if the user is the teacher themselves or an admin.
     * @allow (create, update) if the user is the owner (for profile setup) or an admin.
     * @allow (delete) if the user is an admin.
     * @principle Restricts profile management to the owner and administrative staff.
     */
    match /teachers/{teacherId} {
      allow get, list: if isOwner(teacherId) || isAdmin();
      allow create: if isOwner(teacherId) && request.resource.data.id == teacherId;
      allow update: if (isOwner(teacherId) || isAdmin()) && resource != null && request.resource.data.id == teacherId;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Rules for Parent profiles.
     * @path /parents/{parentId}
     * @allow (get, list) if the user is the parent themselves or an admin.
     * @allow (create, update) if the user is the owner or an admin.
     * @allow (delete) if the user is an admin.
     * @principle Ensures parents can only access their own profile information.
     */
    match /parents/{parentId} {
      allow get, list: if isOwner(parentId) || isAdmin();
      allow create: if isOwner(parentId) && request.resource.data.id == parentId;
      allow update: if (isOwner(parentId) || isAdmin()) && resource != null && request.resource.data.id == parentId;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Rules for Class data. Relies on homeroomTeacherId for teacher access.
     * @path /classes/{classId}
     * @allow (get, list) if user is admin or the assigned homeroom teacher.
     * @allow (create, delete) if user is admin.
     * @allow (update) if user is admin or the assigned teacher.
     * @principle Denormalization of homeroomTeacherId enables secure teacher access.
     */
    match /classes/{classId} {
      // For get/list, resource might not exist yet if it's a list operation.
      // But for single get, it always exists. For list, the rules are applied to each document.
      allow get, list: if isAdmin() || (resource != null && isAssignedTeacher(resource.data.homeroomTeacherId));
      allow create: if isAdmin();
      allow update: if resource != null && (isAdmin() || isAssignedTeacher(resource.data.homeroomTeacherId));
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Rules for Student records. High sensitivity, multiple authorized viewers.
     * @path /students/{studentId}
     * @allow (get, list) if admin, assigned homeroom teacher, or an associated parent.
     * @allow (create, delete) if user is admin.
     * @allow (update) if user is admin or the assigned teacher.
     * @principle Uses denormalized teacher and parent IDs for performant, multi-role access.
     */
    match /students/{studentId} {
      // For get/list, resource might not exist yet if it's a list operation.
      // But for single get, it always exists. For list, the rules are applied to each document.
      allow get, list: if isAdmin() || (resource != null && isAssignedTeacher(resource.data.homeroomTeacherId)) || (resource != null && isAssociatedParent(resource.data.parentIds));
      allow create: if isAdmin();
      allow update: if resource != null && (isAdmin() || isAssignedTeacher(resource.data.homeroomTeacherId));
      allow delete: if isAdmin() && resource != null;
    }
  }
}