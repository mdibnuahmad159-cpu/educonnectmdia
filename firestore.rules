
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'mdibnuahmad159@gmail.com'
      );
    }

    // Default rules for authenticated users
    // Allow read for anyone signed in to ensure listing/queries work across all collections
    match /{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // School profile is read-only for public
    match /schoolProfile/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Additional explicit rules for collections used in queries to ensure no "list" method issues
    match /student_attendances/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /teacher_attendances/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /savingsTransactions/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /sppPayments/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /announcements/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /grades/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /certificates/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
