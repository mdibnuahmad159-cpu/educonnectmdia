
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'mdibnuahmad159@gmail.com' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    // Publicly readable school profile
    match /schoolProfile/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Collections accessible to any signed-in user
    match /announcements/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /teachers/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /students/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /classes/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /curriculum/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /alumni/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /schedules/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /grades/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /report_summaries/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /certificates/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /certificate_templates/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /sppPayments/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /externalSavers/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /savingsTransactions/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /teacher_attendances/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /student_attendances/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // Global admin fallback
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
