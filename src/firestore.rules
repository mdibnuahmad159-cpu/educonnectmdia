
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'mdibnuahmad159@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Default rules for authenticated users
    match /{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // School profile is read-only for public if needed, write for admin
    match /schoolProfile/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Specific rules for savings transactions to allow listing
    match /savingsTransactions/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
