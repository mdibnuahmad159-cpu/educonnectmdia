
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'mdibnuahmad159@gmail.com' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    // Administrator has full access to everything
    match /{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Explicitly allow reading for school profile without login if needed for landing page
    match /schoolProfile/{id} {
      allow read: if true;
    }
    
    // Additional granular rules if needed in the future
    match /savingsTransactions/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /externalSavers/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
