
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Fungsi pembantu untuk mengecek status login
    function isSignedIn() {
      return request.auth != null;
    }

    // Fungsi pembantu untuk mengecek apakah user adalah admin utama
    function isAdmin() {
      return isSignedIn() && (request.auth.token.email == 'mdibnuahmad159@gmail.com' || request.auth.uid == 'ILjpJZ1CcEhC6qlN9JpHwj0Bj773');
    }
    
    // Fungsi pembantu untuk mengecek apakah user adalah guru
    // Guru adalah pengguna terdaftar yang bukan anonim dan memiliki dokumen di koleksi teachers
    function isTeacher() {
      return isSignedIn() && 
             (exists(/databases/$(database)/documents/teachers/$(request.auth.uid)) || 
              (request.auth.token.email != null && !request.auth.token.anonymous));
    }

    // Aturan Global: 
    // 1. Semua pengguna yang login bisa membaca data
    // 2. Hanya admin utama yang bisa melakukan penulisan secara umum
    match /{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Izin spesifik untuk Guru (Input Nilai, Absensi, dan Tabungan)
    // Menggunakan write yang mencakup create dan update
    match /grades/{id} {
      allow write: if isAdmin() || isTeacher();
    }
    
    match /student_attendances/{id} {
      allow write: if isAdmin() || isTeacher();
    }
    
    match /report_summaries/{id} {
      allow write: if isAdmin() || isTeacher();
    }
    
    match /savingsTransactions/{id} {
      allow write: if isAdmin() || isTeacher();
    }

    // Pengecualian khusus: Profil sekolah bisa dibaca publik (untuk halaman login)
    match /schoolProfile/{id} {
      allow read: if true;
    }
    
    // Izin spesifik untuk template sertifikat
    match /certificate_templates/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
