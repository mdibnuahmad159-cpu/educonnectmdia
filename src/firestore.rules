
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Fungsi pembantu untuk mengecek status login
    function isSignedIn() {
      return request.auth != null;
    }

    // Fungsi pembantu untuk mengecek apakah user adalah admin utama
    function isAdmin() {
      return isSignedIn() && (request.auth.token.email == 'mdibnuahmad159@gmail.com' || request.auth.uid == 'ILjpJZ1CcEhC6qlN9JpHwj0Bj773');
    }

    // Aturan Global: 
    // 1. Semua pengguna yang login bisa membaca data
    // 2. Hanya admin utama yang bisa melakukan penulisan (create, update, delete)
    match /{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Pengecualian khusus: Profil sekolah bisa dibaca publik (untuk halaman login)
    match /schoolProfile/{id} {
      allow read: if true;
    }
    
    // Izin spesifik untuk template sertifikat agar lebih aman
    match /certificate_templates/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
